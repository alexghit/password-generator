{
  "manifest_version": 3,
  "name": "Password Generator",
  "version": "1.0",
  "description": "Generate strong passwords. Nothing leaves your machine.",
  "homepage_url": "https://passwords.hey5.studio",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Password Generator"
  },
  "permissions": [
    "storage"
